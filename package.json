{
  "name": "market",
  "version": "1.0.0",
  "description": "Free no-account market data runner with JSON logs and one API endpoint.",
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "update": "node server.js update",
    "summary": "node server.js summary",
    "check": "node --check server.js && node --check test/smoke.js",
    "test": "npm run check && node test/smoke.js",
    "smoke": "node test/smoke.js",
    "smoke:live": "LIVE_SMOKE=true node test/smoke.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "express": "^4.19.2"
  }
}
